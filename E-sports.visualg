algoritmo "lol"

var
  idade: inteiro
inicio
  escreval("Qual sua idade caro jogador ?")
  leia(idade)
  se idade >= 12 e idade <= 14 entao
    escreval("Mirim")
  senao
    se idade >= 15 e idade <= 17 entao
      escreval("Júnior")
    senao
      se idade >= 18 e idade <= 25 entao
        escreval("Profissional")
      senao
        escreval("Master")
      fimse
    fimse
  fimse


fimalgoritmo
